#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include <OneWire.h>
#include <DallasTemperature.h>
#include <WiFi.h>
#include <WebServer.h>
#include <esp_wifi.h>
 
#define ONE_WIRE_BUS 4
 
OneWire oneWire(ONE_WIRE_BUS);
DallasTemperature sensors(&oneWire);
LiquidCrystal_I2C lcd(0x27, 16, 2);
WebServer server(80);
 
const char* ssid     = "teplotni_cidlo_DOUSA";
const char* password = "hahahaLdawdadd";
 
float teplota = 0.0;
 
void nastavIP() {
  esp_netif_t* ap_netif = esp_netif_get_handle_from_ifkey("WIFI_AP_DEF");
  if (ap_netif == NULL) return;
 
  esp_netif_ip_info_t ip_info;
  IP4_ADDR(&ip_info.ip,      192, 168, 67, 67);
  IP4_ADDR(&ip_info.gw,      192, 168, 67,  1);
  IP4_ADDR(&ip_info.netmask, 255, 255, 255,  0);
 
  esp_netif_dhcps_stop(ap_netif);
  esp_netif_set_ip_info(ap_netif, &ip_info);
  esp_netif_dhcps_start(ap_netif);
}
 
byte stupen[8] = {
  0b00110,
  0b01001,
  0b01001,
  0b00110,
  0b00000,
  0b00000,
  0b00000,
  0b00000
};
 
void handleRoot() {
  String html = "<!DOCTYPE html><html><head>";
  html += "<meta charset='UTF-8'>";
  html += "<meta http-equiv='refresh' content='2'>";
  html += "<title>Teplota</title>";
  html += "<style>";
  html += "* { margin: 0; padding: 0; box-sizing: border-box; }";
  html += "body { background: #000; display: flex; justify-content: center; align-items: center; height: 100vh; font-family: Arial, sans-serif; }";
  html += ".teplota { font-size: 20vw; color: #fff; font-weight: bold; }";
  html += "</style></head><body>";
  html += "<div class='teplota'>" + String(teplota, 1) + "&deg;C</div>";
  html += "</body></html>";
  server.send(200, "text/html", html);
}
 
void setup() {
  Serial.begin(115200);
  sensors.begin();
 
  lcd.init();
  lcd.backlight();
  lcd.createChar(0, stupen);
 
  lcd.setCursor(0, 0);
  lcd.print("Spoustim AP...");
 
  WiFi.persistent(false);
  WiFi.mode(WIFI_AP);
  esp_wifi_set_ps(WIFI_PS_NONE);
 
  wifi_ap_config_t ap_config = {};
  memcpy(ap_config.ssid, ssid, strlen(ssid));
  memcpy(ap_config.password, password, strlen(password));
  ap_config.ssid_len = strlen(ssid);
  ap_config.channel = 6;
  ap_config.authmode = WIFI_AUTH_WPA2_PSK;
  ap_config.max_connection = 4;
  ap_config.beacon_interval = 50;
  esp_wifi_set_config(WIFI_IF_AP, (wifi_config_t*)&ap_config);
 
  WiFi.softAP(ssid, password);
  delay(300);
 
  nastavIP();
 
  Serial.println("AP spusteno");
  Serial.print("SSID: ");
  Serial.println(ssid);
  Serial.print("IP adresa: ");
  Serial.println(WiFi.softAPIP());
 
  server.on("/", handleRoot);
  server.begin();
  Serial.println("Web server spusten");
 
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("IP:");
  lcd.setCursor(0, 1);
  lcd.print(WiFi.softAPIP());
  delay(3000);
}
 
void loop() {
  sensors.requestTemperatures();
  teplota = sensors.getTempCByIndex(0);
 
  // Seriovy monitor - znak stupne je Unicode \u00B0
  Serial.print("Teplota: ");
  Serial.print(teplota, 1);
  Serial.print("\xC2\xB0");  // znak ° v UTF-8
  Serial.println("C");
 
  // LCD radek 1
  lcd.setCursor(0, 0);
  lcd.print("Teplota:        ");
 
  // LCD radek 2 - 2 desetinna mista
  lcd.setCursor(0, 1);
  lcd.print(teplota, 2);
  lcd.write(byte(0));
  lcd.print("C       ");
 
  server.handleClient();
  delay(1000);
}
